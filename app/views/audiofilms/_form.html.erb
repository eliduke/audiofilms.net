<%= form_for(@audiofilm) do |f| %>
  <% if @audiofilm.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@audiofilm.errors.count, "error") %> prohibited this audiofilm from being saved:</h2>

      <ul>
      <% @audiofilm.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %><br>
    <%= f.text_field :title, class: "form-control input-lg" %>
  </div>
  <div class="field">
    <%= f.label :description %><br>
    <%= f.text_area :description, class: "form-control input" %>
  </div>
	<div class="row">
		<div class="col-sm-6">
		  <div class="field">
		    <%= f.label :release, "Release Date" %><br>
		    <%= f.date_select :release, {start_year: 1950}, {class: "form-control input-sm", style: "width:32%; display:inline"} %>
		  </div>
		</div>
		<div class="col-sm-6">
		  <div class="field">
		    <%= f.label :slug %><br>
		    <%= f.text_field :slug, class: "form-control input-sm" %>
		  </div>
		</div>
	</div>
  <div class="actions">
		<% button_text = action_name == "new" ? "Create AudioFilm" : "Update AudioFilm" %>
    <%= f.submit button_text, :class => "btn btn-default btn-block"  %>
  </div>
<% end %>