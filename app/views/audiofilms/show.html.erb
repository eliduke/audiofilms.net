<div class="row">
	<div class="col-sm-8">
		<h2 class="well well-sm"><%= @audiofilm.title %></h2>
		<p><%= @audiofilm.release.strftime("%B #{@audiofilm.release.day.ordinalize}, %Y") %></p>
		<p><%= @audiofilm.description %></p>
		<audio src="http://audiofilms.s3.amazonaws.com/audio/<%= @audiofilm.slug %>.mp3" controls preload></audio>
		<p>If the audio player isn't working, <a href="http://audiofilms.s3.amazonaws.com/audio/<%= @audiofilm.slug %>.mp3">click here for the <%= @audiofilm.title %> MP3</a></p>
	</div>

	<div class="col-sm-4">
		<img class="img-responsive" src="http://audiofilms.s3.amazonaws.com/images/<%= @audiofilm.slug %>.jpg">
	</div>
</div>