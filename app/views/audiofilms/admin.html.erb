<h2 class="well well-sm">Admin / <%= link_to "New", new_path %></h2>
<table class="table table-striped table-hover ">
  <thead>
    <tr>
      <th>Title</th>
      <th>Released</th>
			<th>MP3</th>
			<th>Edit</th>
    </tr>
  </thead>
  <tbody>
		<% @audiofilms.each do |audiofilm| %>
    <tr>
      <td><%= link_to audiofilm.title, slug_path(audiofilm.slug) %></td>
      <td><%= audiofilm.release.strftime("%B #{audiofilm.release.day.ordinalize}, %Y") %></td>
			<td><%= link_to "mp3", "http://audiofilms.s3.amazonaws.com/audio/#{audiofilm.slug}.mp3", target: "_blank" %></td>
			<td><%= link_to "edit", edit_audiofilm_path(audiofilm) %></td>
    </tr>
		<% end %>
	</tbody>
</table>