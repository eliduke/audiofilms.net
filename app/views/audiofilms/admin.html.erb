<h2>Admin / <%= link_to "New", new_path %></h2>
<table class="table table-striped table-hover ">
  <thead>
    <tr>
      <th>Title</th>
      <th>Released</th>
      <th class="text-center">Edit</th>
    </tr>
  </thead>
  <tbody>
    <% @audiofilms.each do |audiofilm| %>
    <tr>
      <td><%= link_to audiofilm.title, slug_path(audiofilm.slug) %></td>
      <td><%= audiofilm.release.strftime("%B #{audiofilm.release.day.ordinalize}, %Y") %></td>
      <td class="text-center">
        <%= link_to edit_path(audiofilm) do %>
          <span class="glyphicon glyphicon-pencil"></span>
        <% end %>
      </td>
    </tr>
    <% end %>
  </tbody>
</table>