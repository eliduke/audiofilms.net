<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>Audiofilms</title>
	<link href="http://bootswatch.com/darkly/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="/css/application.css" type="text/css">
  <%= csrf_meta_tags %>
</head>
<body>

  <div class="navbar navbar-default navbar-fixed-top">
    <div class="container">
      <div class="navbar-header">
        <a href="/" class="navbar-brand">AudioFilms</a>
        <button class="navbar-toggle" type="button" data-toggle="collapse" data-target="#navbar-main">
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
        </button>
      </div>
      <div class="navbar-collapse collapse" id="navbar-main">
        <ul class="nav navbar-nav navbar-right">
          <li><%= link_to "Recent", recent_path %></li>
          <li><%= link_to "Master List", master_list_path %></li>
          <li><%= link_to "Request", "mailto:suggestions@audiofilms.net?subject=I've got an idea for an AudioFilm" %></li>
        </ul>
      </div>
    </div>
  </div>


	<div class="container">
		<%= yield %>
	</div>

	<footer>
		<div class="container">
			<div class="row"><hr /></div>
			<ul class="list-inline">
				<li class="pull-right">Created by <a href="http://eliduke.com" target="_blank">Eli Duke</a></li>
				<li>AudioFilms</li>
				<li><%= link_to "Home", root_path %></li>
        <li><%= link_to "Recent", recent_path %></li>
        <li><%= link_to "Master List", master_list_path %></li>
        <li><%= link_to "Request", "mailto:suggestions@audiofilms.net?subject=I've got an idea for an AudioFilm" %></li>
				<li><%= link_to "Admin", admin_path %></li>
			</ul>
    </div><!-- container -->
  </div><!-- footer -->

  <script src="https://code.jquery.com/jquery-2.1.1.min.js"></script>
	<script src="http://maxcdn.bootstrapcdn.com/bootstrap/3.3.1/js/bootstrap.min.js"></script>

</body>
</html>
